# ============================================================================
# Dump Sniper — 精简版配置 (clean baseline)
# ============================================================================
# 复制为 .env，填入最下方【密钥区】即可；策略字段已按目标规则设好。
# ⚠️ 首次部署保持 DRY_RUN=true，确认有信号、买卖正常后再切 LIVE。
# ============================================================================

# ============ 运行模式 ============
DRY_RUN=true
POSITION_SIZE_SOL=1

# ============ 买入：订单流反转（默认生效）============
#   大卖压只建立 setup；只有随后买量反超卖量、价格从低点确认回弹，才触发买入。
ORDER_FLOW_ENABLED=true
ORDER_FLOW_REPLACE_DUMP_SIGNAL=true
ORDER_FLOW_WINDOW_MS=10000
ORDER_FLOW_CONFIRM_WINDOW_MS=4000
ORDER_FLOW_BUY_GRACE_MS=700
ORDER_FLOW_MIN_SELL_SOL=20
ORDER_FLOW_MIN_DROP_PCT=12
ORDER_FLOW_MAX_DROP_PCT=30
ORDER_FLOW_MIN_SELL_COUNT=2
ORDER_FLOW_MIN_UNIQUE_SELLERS=2
ORDER_FLOW_MIN_BUY_SOL=3
ORDER_FLOW_MIN_ABSORB_RATIO=0.25
ORDER_FLOW_MIN_BUY_SELL_RATIO=1.25
ORDER_FLOW_MIN_IMBALANCE=0.15
ORDER_FLOW_MIN_UNIQUE_BUYERS=2
ORDER_FLOW_MIN_REBOUND_PCT=1.5
ORDER_FLOW_MAX_REBOUND_PCT=8
ORDER_FLOW_MIN_LOW_AGE_MS=300
ORDER_FLOW_MAX_CANDIDATE_AGE_MS=8000
ORDER_FLOW_COOLDOWN_MS=60000
ORDER_FLOW_DEBUG=false

# ============ 旧砸单阈值：setup / 安全护栏 / fallback 使用，不再直接买入 ============
MIN_SELL_SOL=20
MIN_PRICE_IMPACT_PCT=10
MIN_TRIGGER_SELL_COUNT=2
NEW_COIN_MIN_IMPACT_PCT=10
MAX_PRICE_IMPACT_PCT=30        # 安全护栏：跌幅 >30% 视为已 rug，不接
MIN_POOL_QUOTE_SOL=30          # 安全护栏：池子 SOL <30 不买

# ============ 卖出 ============
#   快速止盈 5% / 移动止盈 +10%激活、回撤 3%卖 / 固定止盈 +20% / 固定止损 -25% / 超时 30min
FAST_PROFIT_EXIT_PCT=5
FAST_PROFIT_MIN_SAMPLES=3
TRAILING_ACTIVATE_PCT=10
TRAILING_DRAWDOWN_PCT=3
TRAILING_MIN_HWM_AGE_MS=2000
TAKE_PROFIT_PCT=20
EMERGENCY_STOP_LOSS_PCT=-25
MAX_HOLD_MS=1800000           # 30min 兜底超时强制退出
STABILIZATION_MS=5000
STABILIZATION_EMERGENCY_DRAWDOWN_PCT=20

# ============ 监控列表过滤（TokenWatchdog，每 15s 巡检）============
#   FDV $3万~$100万 之外移除 / age >24h 移除 / 24h量 <$5000 移除
MIN_FDV_USD=30000
MAX_FDV_USD=1000000
MIN_VOLUME_24H_USD=5000
MAX_TOKEN_AGE_MS=86400000
NEW_COIN_AGE_THRESHOLD_MS=86400000
WATCHDOG_CHECK_INTERVAL_MS=15000

# ============================================================================
# ⚠️ 关键「关闭开关」——代码默认会启用这些旧机制，删除/留空会改变行为，勿删！
# ============================================================================
LOW_PEAK_TIMEOUT_MS=0            # 代码默认 30min 低峰割肉 → 关
DEFENSE_ACTIVATE_MS=0            # 代码默认 20min 启用防御模式 → 关
DEFENSE_STOP_LOSS_PCT=0         # 代码默认 -10
DEFENSE_TRAILING_DRAWDOWN_PCT=0 # 代码默认 3
DEFENSE_PROFIT_ACTIVATE_PCT=0   # 代码默认 3
NO_BUY_REMOVE_MS=0              # 代码默认 24h 未买入即移除 → 关
OLD_COIN_MIN_POOL_SOL=0         # 代码默认 100 → 关
MAX_DUMP_DEPTH_PCT=0           # 代码默认 50（砸盘 >50% 拒绝）→ 关
MAX_PRE_VOL_5M_PCT=0          # 代码默认 15（砸前 5min 量过滤）→ 关
MAX_WATCH_DURATION_MS=0
# ⚠️ 下面两个：留空会回退到上面的 MAX/MIN_FDV_USD，导致信号期 FDV 误拒（你遇到的"没信号"诱因之一），必须显式 0
SIGNAL_MAX_FDV_USD=0
SIGNAL_MIN_FDV_USD=0

# ============ 实验性出场/过滤：冗余保险（代码默认已关，显式 0 防被改回开启）============
RANGE_STOP_ENABLED=0
TREND_STOP_ENABLED=0
TIMED_TP_ENABLED=0
EARLY_LOW_PEAK_CUT_ENABLED=0
TREND_FILTER_ENABLED=0
RSI_FILTER=off
RSI_30S_MIN=0

# ============ 信号去重 / 新鲜度 / 风控 ============
MAX_SIGNAL_SLOT_GAP=200       # 砸单 slot 落后 >200(~80s) 丢弃（防迟到接刀）。勿设 0
MAX_PUSH_LAG_MS=5000
SELLER_TX_DEDUP_MS=600000
SELLER_MINT_DEDUP_MS=30000
COOLDOWN_MS_PER_TOKEN=60000
REBUY_COOLDOWN_MS=60000
MAX_CONCURRENT_POSITIONS=60
PRICE_MAX_JUMP_RATIO=1.5
PRICE_CONFIRM_WINDOW_MS=3000
PRICE_CONFIRM_MIN_SAMPLES=2
POSITION_MAX_JUMP_RATIO=5
POSITION_EXTREME_RATIO=50

# ============ Pool 状态缓存（零延迟买入路径，勿改）============
POOL_POLL_INTERVAL_MS=500
POOL_STATE_POSITION_REFRESH_MS=500
POOL_STATE_SIGNAL_REFRESH_MS=2000
POOL_STATE_TICK_MS=200
AUTO_FILL_POOLS_ON_START=true

# ============ 滑点 / 优先费 / Jito ============
BUY_SLIPPAGE_BPS=2500
SELL_SLIPPAGE_BPS=500
PRIORITY_FEE_DYNAMIC=false
BUY_PRIORITY_LEVEL=veryHigh
SELL_PRIORITY_LEVEL=medium
BUY_MIN_PRIORITY_FEE_LAMPORTS=5000000
SELL_MIN_PRIORITY_FEE_LAMPORTS=500000
BUY_CAP_PRIORITY_FEE_LAMPORTS=30000000
SELL_CAP_PRIORITY_FEE_LAMPORTS=500000
BUY_MAX_PRIORITY_FEE_LAMPORTS=5000000
SELL_MAX_PRIORITY_FEE_LAMPORTS=500000
MAX_PRIORITY_FEE_LAMPORTS=5000000
PRIORITY_FEE_REFRESH_MS=500
JITO_TIP_LAMPORTS=200000
COMPUTE_UNIT_LIMIT=185000

# ============ 杂项 / 稳定性 ============
SOL_PRICE_USD=72
MAX_REPLAY_SLOTS=5            # LaserStream 重连最多回放 5 slot（防 RSS 死亡螺旋）。勿改
MAX_UPTIME_MS=10800000        # 空仓时每 3h 自动重启释放 native 内存
COMPETITOR_ENRICH=false
COMPETITOR_FOLLOW_SELL=false

# ============================================================================
# 【密钥区】—— 必填，从旧服务器 .env 复制 ——
# ============================================================================
HELIUS_API_KEY=
HELIUS_RPC_URL=
HELIUS_STAKED_RPC_URL=
HELIUS_SENDER_ENDPOINT=https://sender.helius-rpc.com/fast
HELIUS_SENDER_ENDPOINTS=http://fra-sender.helius-rpc.com/fast,http://ewr-sender.helius-rpc.com/fast,http://tyo-sender.helius-rpc.com/fast
HELIUS_LASERSTREAM_ENDPOINT=https://laserstream-mainnet-fra.helius-rpc.com
HELIUS_LASERSTREAM_ENDPOINTS=https://laserstream-mainnet-fra.helius-rpc.com,https://laserstream-mainnet-ewr.helius-rpc.com,https://laserstream-mainnet-tyo.helius-rpc.com
HELIUS_LASERSTREAM_TOKEN=
BIRDEYE_API_KEY=
WALLET_PRIVATE_KEY_BS58=

# ============ Dashboard ============
DASHBOARD_PORT=3001
BIND_HOST=0.0.0.0
WEBHOOK_SECRET=
DASHBOARD_TOKEN=
